# ====================== ENVIRONMENT VARIABLES ======================

# MongoDB
MONGO_URI=mongodb://localhost:27017/myntra

# JWT Authentication
JWT_SECRET=your_super_long_random_jwt_secret_key_here_change_in_production

# Razorpay (Test Mode Recommended)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_test_secret_here

# OpenRouter AI (for Chat, Embeddings, Visual Search)
OPENROUTER_API_KEY=sk-or-v1-your_key_here_put_your_own_key

# Port
PORT=5000

# Frontend API Base
VITE_API_BASE=http://localhost:5000